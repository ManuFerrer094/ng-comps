{
  "$schema": "./node_modules/ng-packagr/ng-package.schema.json",
  "dest": "./dist/ng-comps",
  "lib": {
    "entryFile": "src/public-api.ts"
  },
  "assets": [
    "LICENSE",
    "README.md",
    "src/styles.css",
    "src/theme/**/*"
  ],
  "allowedNonPeerDependencies": [
    "@angular/animations",
    "@angular/cdk",
    "@angular/common",
    "@angular/compiler",
    "@angular/core",
    "@angular/forms",
    "@angular/material",
    "@angular/platform-browser",
    "@angular/router",
    "@fontsource/material-icons",
    "rxjs",
    "tslib"
  ]
}
